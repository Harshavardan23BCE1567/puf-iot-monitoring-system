{
  "name": "puf-iot-system",
  "version": "2.0.0",
  "description": "Professional PUF hardware monitoring system with realtime dashboard",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "dev:frontend": "cd Dashboard && npm run dev",
    "build:frontend": "cd Dashboard && npm run build",
    "build": "npm run build:frontend",
    "preview": "cd Dashboard && npm run preview"
  },
  "keywords": [
    "puf",
    "hardware",
    "iot",
    "security",
    "monitoring"
  ],
  "author": "Muthuram",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "serialport": "^11.0.0",
    "@serialport/parser-readline": "^11.0.0",
    "sqlite3": "^5.1.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "compression": "^1.7.4",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "eslint": "^8.53.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
